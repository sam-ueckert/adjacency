# Credential store for crawl-based discovery.
# Copy to credentials.yaml and fill in your credentials.
#
# Credentials are tried in order.  Entries with explicit 'networks'
# are tried first (scoped), then entries without networks (wildcards).
#
# platform values use NAPALM driver names:
#   ios, eos, junos, nxos_ssh, iosxr, etc.
# If omitted, the crawler auto-detects platform from LLDP/CDP data.

---
credentials:
  # Spine layer — Arista EOS
  - name: spine-arista
    username: admin
    password: arista123
    platform: eos
    networks:
      - 10.0.0.0/24

  # Leaf layer — Cisco NX-OS
  - name: leaf-nexus
    username: admin
    password: cisco123
    platform: nxos_ssh
    networks:
      - 10.0.1.0/24
      - 10.0.2.0/24

  # Access layer — Cisco IOS with enable secret
  - name: access-ios
    username: netops
    password: acc3ss
    secret: en4ble!
    platform: ios
    networks:
      - 10.1.0.0/16

  # Fallback — try this for any device not matching above
  - name: fallback
    username: admin
    password: admin
